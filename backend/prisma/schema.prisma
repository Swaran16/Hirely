// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User model
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  resumes      Resume[]
  applications Application[]
}

// Resume model
model Resume {
  id        String   @id @default(cuid())
  userId    String
  fileName  String
  fileUrl   String?
  content   String?  @db.Text
  skills    String[] // Array of skills
  experience Json?   // JSON for structured experience
  education  Json?   // JSON for education
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Job model (cached from APIs)
model Job {
  id          String   @id @default(cuid())
  externalId  String   @unique // ID from job API
  title       String
  company     String
  location    String?
  description String?  @db.Text
  salary      String?
  url         String
  source      String   // "adzuna", "rapidapi", etc.
  skills      String[] // Required skills
  postedAt    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  applications Application[]
}

// Application tracking
model Application {
  id        String   @id @default(cuid())
  userId    String
  jobId     String
  status    ApplicationStatus @default(SAVED)
  matchScore Float?
  notes     String?
  appliedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
}

enum ApplicationStatus {
  SAVED
  APPLIED
  INTERVIEW
  REJECTED
  OFFER
}